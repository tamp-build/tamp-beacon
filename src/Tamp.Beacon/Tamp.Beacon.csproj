<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <RootNamespace>Tamp.Beacon</RootNamespace>
    <AssemblyName>Tamp.Beacon</AssemblyName>
    <IsPackable>false</IsPackable>
    <InvariantGlobalization>true</InvariantGlobalization>
    <UserSecretsId>tamp-beacon-dev</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Konscious.Security.Cryptography.Argon2" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="Google.Protobuf" />
    <PackageReference Include="Grpc.Tools">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <!--
    OTLP proto types — generated under OpenTelemetry.Proto.* namespaces by
    Grpc.Tools at build time. We pin protos/ as the proto-include root so
    the generated `using OpenTelemetry.Proto.Trace.V1` namespace matches the
    .proto package declarations.
  -->
  <ItemGroup>
    <Protobuf Include="protos\opentelemetry\proto\**\*.proto"
              ProtoRoot="protos"
              GrpcServices="None"
              CompileOutputs="true" />
  </ItemGroup>

  <!--
    Slice 1 scope = scaffold + bootstrap + health. The pre-pivot
    implementation's OTLP receivers, Web Push, and dashboard endpoints
    are kept on disk (preserved in v0.0.1-archive) but excluded from
    compilation until their respective slices land. Re-including them
    progressively:
      Slice 4 — re-include Otlp/** + Api/OtlpEndpoints.cs + Api/BuildsEndpoints.cs
                + Api/ProjectsEndpoints.cs + Api/TargetsEndpoints.cs
      Slice 6 — re-include Push/** + Api/PushEndpoints.cs
  -->
  <ItemGroup>
    <Compile Remove="Api\BuildsEndpoints.cs" />
    <Compile Remove="Api\TargetsEndpoints.cs" />
    <Compile Remove="Api\PushEndpoints.cs" />
    <Compile Remove="Push\**\*.cs" />
  </ItemGroup>

</Project>
