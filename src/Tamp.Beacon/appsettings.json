{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Beacon": {
    "ConnectionString": "Host=/var/lib/tamp-beacon/postgres;Username=beacon;Database=beacon",
    "SetupTokenPath": "/var/lib/tamp-beacon/setup.token",
    "VapidKeyPath": "/var/lib/tamp-beacon/vapid.key",
    "VapidSubject": "mailto:beacon@tamp.local",
    "Auth": {
      "SetupTokenTtlSeconds": 3600,
      "SetupTokenEntropyBytes": 32,
      "Argon2MemoryKib": 65536,
      "Argon2Iterations": 3,
      "Argon2Parallelism": 1
    }
  }
}
