<?xml version="1.0" encoding="utf-8"?>
<!--
  Local override for testing pre-release Tamp.Core 1.10.0 + Tamp.Telegram
  0.1.0 (TAM-230) before they ship to nuget.org. Adds Scott's machine-local
  feed alongside the canonical nuget.org source — packages resolved from
  whichever has the newest matching version.

  When the Tamp.Core 1.10.0 + Tamp.Telegram 0.1.0 packages ship to nuget.org,
  this file can be deleted; the default nuget.org-only resolution takes
  over without code change.
-->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="local-pending" value="/Users/scott/.local-nuget-feed" />
  </packageSources>
</configuration>
